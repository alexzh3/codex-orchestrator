{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alexzh3.github.io/codex-orchestrator/schemas/verification.schema.json",
  "title": "Codex Orchestrator Verification Record",
  "type": "object",
  "required": [
    "type",
    "kind",
    "result",
    "recorded_at",
    "summary"
  ],
  "properties": {
    "type": {
      "type": "string",
      "const": "verification"
    },
    "kind": {
      "type": "string",
      "enum": [
        "git_diff",
        "test",
        "typecheck",
        "lint",
        "build",
        "benchmark",
        "screenshot",
        "artifact_check",
        "manual_review",
        "custom"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "skipped",
        "inconclusive",
        "needs_human_review"
      ]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string"
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "stochastic": {
      "type": "boolean"
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "string",
          "boolean",
          "null"
        ]
      }
    }
  },
  "additionalProperties": false
}
