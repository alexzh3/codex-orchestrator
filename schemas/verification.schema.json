{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alexzh3.github.io/codex-orchestrator/schemas/verification.schema.json",
  "title": "Codex Orchestrator Verification Record",
  "type": "object",
  "required": [
    "check",
    "status",
    "recorded_at"
  ],
  "properties": {
    "check": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "skipped"
      ]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "command": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "stochastic": {
      "type": "boolean"
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "string",
          "boolean",
          "null"
        ]
      }
    }
  },
  "additionalProperties": false
}
