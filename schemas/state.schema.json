{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alexzh3.github.io/codex-orchestrator/schemas/state.schema.json",
  "title": "Codex Orchestrator Run State",
  "type": "object",
  "required": [
    "run_id",
    "repo",
    "created_at",
    "status",
    "sessions",
    "verification_policy"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "pattern": "^/"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "blocked",
        "complete",
        "needs_review",
        "accepted",
        "rejected"
      ]
    },
    "sessions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/session"
      }
    },
    "verification_policy": {
      "$ref": "#/$defs/verification_policy"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "session": {
      "type": "object",
      "required": [
        "name",
        "thread_id",
        "mode",
        "rollout_path",
        "branch",
        "worktree",
        "status",
        "last_seen_at"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "thread_id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "ide",
            "exec"
          ]
        },
        "rollout_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "worktree": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "idle",
            "complete",
            "failed",
            "awaiting-approval",
            "unknown"
          ]
        },
        "last_seen_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "verification_policy": {
      "type": "object",
      "required": [
        "required",
        "forbidden"
      ],
      "properties": {
        "required": {
          "$ref": "#/$defs/string_list"
        },
        "forbidden": {
          "$ref": "#/$defs/string_list"
        },
        "nondeterministic_rollouts": {
          "$ref": "#/$defs/string_list"
        }
      },
      "additionalProperties": false
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
