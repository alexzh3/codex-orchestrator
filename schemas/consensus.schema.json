{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alexzh3.github.io/codex-orchestrator/schemas/consensus.schema.json",
  "title": "Codex Orchestrator Consensus Record",
  "type": "object",
  "required": [
    "recorded_at",
    "finding",
    "resolution",
    "evidence"
  ],
  "properties": {
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "finding": {
      "type": "string",
      "minLength": 1
    },
    "root_cause": {
      "type": "string"
    },
    "resolution": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "accepted",
        "rejected",
        "deferred"
      ]
    }
  },
  "additionalProperties": false
}
